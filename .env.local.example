# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT (.env.local)
# Copy this to .env.local and use the LOCAL section for offline dev.
# ─────────────────────────────────────────────────────────────────────────────

# ── Local SQLite database (no Supabase account needed) ────────────────────────
# 1. Run:  npm run db:setup   (creates local.db with test data)
# 2. Set these two vars, leave all Supabase vars blank:
USE_LOCAL_DB=true
LOCAL_DB_PATH=./local.db   # optional — defaults to ./local.db

# ── Supabase (production / staging) ──────────────────────────────────────────
# Leave blank when USE_LOCAL_DB=true
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ────────────────────────────────────────────────────────────────────
# Use Stripe test keys for local dev — checkout will work end-to-end
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...    # from: stripe listen --forward-to localhost:3000/api/webhook

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=local-dev-secret-change-me
NEXTAUTH_URL=

# ── Admin login ───────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@klickables.com.au
# Generate hash: node -e "require('bcryptjs').hash('yourpassword', 10).then(console.log)"
ADMIN_PASSWORD_HASH=$2b$10$...

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Leave blank locally — emails are silently skipped if API key is missing
RESEND_API_KEY=
EMAIL_FROM=orders@klickables.com.au
